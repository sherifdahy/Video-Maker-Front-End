# Frontend Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# API Configuration
# Local Development
VITE_API_URL=http://localhost:3001

# Production (Railway)
# VITE_API_URL=https://video-maker-backend-prod.up.railway.app

# App Configuration
VITE_APP_NAME=Video Maker
VITE_APP_VERSION=2.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true
